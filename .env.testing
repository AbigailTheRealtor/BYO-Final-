APP_NAME=Laravel
APP_ENV=testing
APP_KEY=base64:J8A5HGWjmS++DlqWzqXgRhWvRmjg/2j5yIqaW6YnEBY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

BROADCAST_DRIVER=log
CACHE_DRIVER=array
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
SESSION_LIFETIME=120

MAIL_MAILER=array
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=test@example.com
MAIL_FROM_NAME="Laravel Test"

TELESCOPE_ENABLED=false
BCRYPT_ROUNDS=4

# ── Google Places safeguards (see docs/investigations/Google-Places-Root-Cause-Analysis.md) ──
# The key MUST be blank in testing so no code path can ever authenticate a live
# NearbySearch call. tests/TestCase.php throws a RuntimeException if a real key
# leaks in as a system env var. The kill switch stays OFF by default; a test that
# deliberately exercises the pipeline with a mocked client opts in per-test.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_ENABLED=false
GOOGLE_PLACES_DAILY_LIMIT=100
GOOGLE_PLACES_HOURLY_LIMIT=25
