modules = ["php-8.2", "web", "nodejs-20", "python-3.11", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["unzip", "orbiton"]

[userenv]

[userenv.shared]
DB_CONNECTION = "pgsql"
DB_HOST = "helium"
DB_PORT = "5432"
DB_DATABASE = "heliumdb"
DB_USERNAME = "postgres"
DB_PASSWORD = "password"
APP_NAME = "BidYourOffer"
APP_ENV = "local"
APP_DEBUG = "true"
APP_URL = "https://3ce01d2c-f79e-44c2-b048-2e8dc64316ef-00-tu7aronbf5wk.spock.replit.dev"
CACHE_DRIVER = "file"
SESSION_DRIVER = "file"
QUEUE_CONNECTION = "sync"
BROADCAST_DRIVER = "log"
ASSET_URL = "https://3ce01d2c-f79e-44c2-b048-2e8dc64316ef-00-tu7aronbf5wk.spock.replit.dev"

[userenv.development]
ASK_AI_ENABLE_OPENAI_INTENT_NORMALIZATION = "true"
OPENAI_MODEL = "gpt-4o-2024-08-06"
OPENAI_PROMPT_VERSION = "property-dna-report-v1.0"
MAIL_MAILER = "log"
ASK_AI_ENABLE_DESCRIPTION_FALLBACK = "true"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Laravel Server"

[[workflows.workflow]]
name = "Laravel Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PHP_INI_SCAN_DIR=\"$PWD/deploy/php\" php artisan serve --host=0.0.0.0 --port=5000"
waitForPort = 5000

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "PHP_INI_SCAN_DIR=\"$PWD/deploy/php\" php artisan serve --host=0.0.0.0 --port=5000"]
build = ["composer", "install", "--no-dev", "--optimize-autoloader", ";", "npm", "install", ";", "npm", "run", "prod", ";", "php", "artisan", "config:cache", ";", "php", "artisan", "route:cache", ";", "php", "artisan", "view:cache"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000
