<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="./vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory suffix="Test.php">./tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory suffix="Test.php">./tests/Feature</directory>
        </testsuite>
    </testsuites>
    <coverage processUncoveredFiles="true">
        <include>
            <directory suffix=".php">./app</directory>
        </include>
    </coverage>
    <php>
        <ini name="memory_limit" value="512M"/>
        <server name="APP_ENV" value="testing"/>
        <server name="BCRYPT_ROUNDS" value="4"/>
        <server name="CACHE_DRIVER" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <server name="MAIL_MAILER" value="array"/>
        <server name="QUEUE_CONNECTION" value="sync"/>
        <server name="SESSION_DRIVER" value="array"/>
        <server name="TELESCOPE_ENABLED" value="false"/>
        <!-- Google Places safeguards (Phase 0 / S1a).
             force="true" is load-bearing: without it PHPUnit will NOT overwrite a
             GOOGLE_PLACES_API_KEY already present in the process environment, which
             is precisely how the 2026-07-05 incident reached live Google from the
             test suite (38,236 requests / ~$1,223 in six days). See
             docs/investigations/Google-Places-Root-Cause-Analysis.md and
             docs/architecture/SPATIAL-INTELLIGENCE-PLATFORM.md erratum E-20.

             Asserted by tests/Feature/Security/GooglePlacesCredentialGuardTest.php. -->
        <server name="GOOGLE_PLACES_API_KEY" value="" force="true"/>
        <server name="GOOGLE_PLACES_ENABLED" value="false" force="true"/>
        <server name="GOOGLE_PLACES_DAILY_LIMIT" value="100" force="true"/>
        <server name="GOOGLE_PLACES_HOURLY_LIMIT" value="25" force="true"/>
    </php>
</phpunit>
