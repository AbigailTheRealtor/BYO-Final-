APP_NAME=Laravel
# Local development defaults below. IN PRODUCTION you MUST set:
#   APP_ENV=production   APP_DEBUG=false   SESSION_SECURE_COOKIE=true
# Leaving APP_ENV=local / APP_DEBUG=true in a deployment leaks stack traces
# and enables local-only debug routes.
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Local-only developer auto-login route (/dev-login/{id}). MUST stay false in
# any deployment. Ignored entirely in the production environment.
DEV_LOGIN_ENABLED=false

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bidoffer
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
# Set to true in production (HTTPS) so the session cookie is marked Secure.
SESSION_SECURE_COOKIE=false

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------
# Mail Configuration
# -----------------------------------------------------------------------
# Development: use MAIL_MAILER=log to write all outgoing mail to
# storage/logs/laravel.log — no mail server required, no 500 errors.
#
# Production: set MAIL_MAILER=smtp and supply real SMTP credentials via
# Replit environment secrets (or your host's secret manager). Example
# providers: Mailgun, SendGrid, Postmark, AWS SES, or any SMTP relay.
#
# Required production secrets:
#   MAIL_MAILER      = smtp
#   MAIL_HOST        = smtp.mailgun.org  (or your provider's host)
#   MAIL_PORT        = 587               (or 465 for SSL)
#   MAIL_USERNAME    = (your SMTP username / API key)
#   MAIL_PASSWORD    = (your SMTP password / API secret)
#   MAIL_ENCRYPTION  = tls               (or ssl)
#   MAIL_FROM_ADDRESS= noreply@yourdomain.com
#   MAIL_FROM_NAME   = "Bid Your Offer"
# -----------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@bidyouroffer.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
# Optional: set only for S3-compatible endpoints (leave empty for real AWS S3).
AWS_ENDPOINT=
AWS_URL=

# -----------------------------------------------------------------------
# R2-A (HI-05A) listing-storage disk selectors — INERT by default.
# Leave on the local disks ('public'/'private'). A later phase flips these
# to 's3_public'/'s3_private' to activate object storage.
# -----------------------------------------------------------------------
LISTING_PUBLIC_DISK=public
LISTING_PRIVATE_DISK=private
# Gate for the explicitly-invoked, read-only `php artisan s3:preflight` check.
STORAGE_S3_PREFLIGHT_ENABLED=false

# -----------------------------------------------------------------------
# Google Maps / Places API
# Required for address autocomplete (seller, landlord, /offers/87, /offers/88)
# and the drawing map (buyer, tenant). Without this key, address fields will
# not autocomplete and property-preference maps will not render.
#
# Set the key value in .env (NOT only as a Replit platform secret — the
# Laravel workflow process reads from .env via phpdotenv at startup; Replit
# platform secrets are not injected into the workflow process environment).
#
# Enable in Google Cloud Console:
#   - Maps JavaScript API
#   - Places API
# -----------------------------------------------------------------------
GOOGLE_PLACES_API_KEY=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Ask AI — Feature Flags
# Enable OpenAI intent normalization for dev/staging. Production default is false (governed).
ASK_AI_ENABLE_OPENAI_INTENT_NORMALIZATION=true

# BYA Compatibility Hidden Beta
BYA_COMPATIBILITY_HIDDEN_BETA_ENABLED=false

# BYA Compatibility Consumer Beta (Milestone 14)
BYA_COMPATIBILITY_CONSUMER_BETA_ENABLED=false

# BYA Compatibility General Availability controls (Milestone 15)
# Kill switch: true = all consumer access denied immediately (safe default)
BYA_COMPATIBILITY_KILL_SWITCH=true
# GA feature flag: false = GA path inactive (independent of consumer beta)
BYA_COMPATIBILITY_GA_ENABLED=false
# Rollout percentage 0–100: deterministic bucket crc32(user_id)%100 < value
BYA_COMPATIBILITY_ROLLOUT_PERCENTAGE=0
# Allowlist (JSON array): users always granted GA access e.g. [1,2,3]
BYA_COMPATIBILITY_ALLOWED_USER_IDS=[]

# Agent AI Assistant V2
# When true, POST /agent-ai/ask and POST /agent-ai/session/start are active (placeholder JSON).
# When false (default), those routes return 404. V1 Ask AI is never affected by this flag.
# GOVERNANCE REVIEW REQUIRED before enabling in production.
AGENT_AI_ASSISTANT_V2=false

# -----------------------------------------------------------------------
# Bridge Integration
# Required for the Bridge MLS data API. Set both values via your host's
# secret manager (Replit environment secrets in production).
#   BRIDGE_DATASET       — the dataset identifier, e.g. "stellar"
#   BRIDGE_SERVER_TOKEN  — your private server-side API token (keep secret)
# -----------------------------------------------------------------------
BRIDGE_DATASET=
BRIDGE_SERVER_TOKEN=

# Lazy-import cache TTL — how many minutes a criteria fetch-cache entry is
# considered fresh before the next search triggers a new Bridge API pull.
BRIDGE_LAZY_TTL_MINUTES=60

# Hard pagination caps for a single lazy-fetch cycle.
# If either limit is reached, pagination stops, a warning is logged, and
# the partial result set is still upserted and cached.
#   BRIDGE_LAZY_MAX_PAGES   — maximum API pages per cycle (each page ≤ 200 records)
#   BRIDGE_LAZY_MAX_RECORDS — maximum total records upserted per cycle
BRIDGE_LAZY_MAX_PAGES=20
BRIDGE_LAZY_MAX_RECORDS=500
# Number of records per API page (Bridge API maximum is 200).
BRIDGE_LAZY_PAGE_SIZE=200
# TTL (minutes) for partial imports (when a max-pages/max-records cap is hit).
# Shorter than BRIDGE_LAZY_TTL_MINUTES so the next request retries sooner.
# Set to 0 to skip caching partial results (forces re-fetch every time).
BRIDGE_LAZY_PARTIAL_TTL_MINUTES=5
