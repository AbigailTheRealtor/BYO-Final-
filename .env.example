APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bidoffer
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# BYA Compatibility Hidden Beta
BYA_COMPATIBILITY_HIDDEN_BETA_ENABLED=false

# BYA Compatibility Consumer Beta (Milestone 14)
BYA_COMPATIBILITY_CONSUMER_BETA_ENABLED=false

# BYA Compatibility General Availability controls (Milestone 15)
# Kill switch: true = all consumer access denied immediately (safe default)
BYA_COMPATIBILITY_KILL_SWITCH=true
# GA feature flag: false = GA path inactive (independent of consumer beta)
BYA_COMPATIBILITY_GA_ENABLED=false
# Rollout percentage 0–100: deterministic bucket crc32(user_id)%100 < value
BYA_COMPATIBILITY_ROLLOUT_PERCENTAGE=0
# Allowlist (JSON array): users always granted GA access e.g. [1,2,3]
BYA_COMPATIBILITY_ALLOWED_USER_IDS=[]
