# Provider-validation connection contract — NON-SECRET TEMPLATE (committed).
#
# Usage: copy to `.env.local` (gitignored), fill in the direct-connection values,
# then `set -a; . ./.env.local; set +a` before invoking run_provider_spike.sh.
#
# SECURITY:
#   * env.example is committed — NEVER put a real secret in it.
#   * Do NOT set PGPASSWORD anywhere. The wrapper deliberately never reads it.
#     Put the password in ~/.pgpass (chmod 600); psql reads it automatically:
#       echo 'HOST:PORT:spike:USER:REDACTED' >> ~/.pgpass && chmod 600 ~/.pgpass

# Provider label — drives results/<provider>/ path. One of:
#   crunchy | digitalocean | neon | rds
PROVIDER=crunchy

# Tier: 1 = committed 176,560-row parity generator (Stage 0a, read-only reuse)
#       2 = deterministic ~5,000,200-row scaled generator (Stage 0b)
TIER=1

# DIRECT, SESSION-MODE connection ONLY.
# Never point these at a transaction-mode pooler (e.g. Neon's -pooler host,
# PgBouncer transaction port) — setseed()/EXPLAIN/CREATE INDEX require a session.
PGHOST=your-direct-host.example.com
PGPORT=5432
PGUSER=spike_tester
PGDATABASE=spike

# TLS to a managed provider is mandatory.
PGSSLMODE=require

# psql 16 client binary (name on PATH or absolute path).
PSQL_BIN=psql
